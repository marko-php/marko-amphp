{
    "name": "marko/amphp",
    "description": "Revolt event loop lifecycle and config integration for Marko Framework",
    "license": "MIT",
    "type": "marko-module",
    "require": {
        "php": "^8.5",
        "amphp/amp": "^3",
        "revolt/event-loop": "^1",
        "marko/core": "self.version",
        "marko/config": "self.version"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "marko/testing": "self.version"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Amphp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Amphp\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
